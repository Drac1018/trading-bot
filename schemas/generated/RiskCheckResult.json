{
  "$defs": {
    "RiskReasonDetail": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "blocking": {
          "default": true,
          "title": "Blocking",
          "type": "boolean"
        },
        "resizable": {
          "default": false,
          "title": "Resizable",
          "type": "boolean"
        },
        "measured_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Measured Value"
        },
        "limit_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Limit Value"
        },
        "detail": {
          "additionalProperties": true,
          "title": "Detail",
          "type": "object"
        }
      },
      "required": [
        "code"
      ],
      "title": "RiskReasonDetail",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed": {
      "title": "Allowed",
      "type": "boolean"
    },
    "decision": {
      "enum": [
        "hold",
        "long",
        "short",
        "reduce",
        "exit"
      ],
      "title": "Decision",
      "type": "string"
    },
    "reason_codes": {
      "description": "Blocker-only alias. Same meaning as blocked_reason_codes.",
      "items": {
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    },
    "blocked_reason_codes": {
      "description": "Actual blocking reasons for the current risk evaluation cycle.",
      "items": {
        "type": "string"
      },
      "title": "Blocked Reason Codes",
      "type": "array"
    },
    "adjustment_reason_codes": {
      "description": "Non-blocking adjustment or approval reasons such as successful auto-resize.",
      "items": {
        "type": "string"
      },
      "title": "Adjustment Reason Codes",
      "type": "array"
    },
    "reason_details": {
      "items": {
        "$ref": "#/$defs/RiskReasonDetail"
      },
      "title": "Reason Details",
      "type": "array"
    },
    "approved_risk_pct": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Approved Risk Pct",
      "type": "number"
    },
    "approved_leverage": {
      "maximum": 10.0,
      "minimum": 0.0,
      "title": "Approved Leverage",
      "type": "number"
    },
    "raw_projected_notional": {
      "default": 0.0,
      "minimum": 0.0,
      "title": "Raw Projected Notional",
      "type": "number"
    },
    "approved_notional": {
      "default": 0.0,
      "minimum": 0.0,
      "title": "Approved Notional",
      "type": "number"
    },
    "approved_projected_notional": {
      "default": 0.0,
      "minimum": 0.0,
      "title": "Approved Projected Notional",
      "type": "number"
    },
    "approved_qty": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved Qty"
    },
    "approved_quantity": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved Quantity"
    },
    "resizable": {
      "default": false,
      "title": "Resizable",
      "type": "boolean"
    },
    "auto_resized_entry": {
      "default": false,
      "title": "Auto Resized Entry",
      "type": "boolean"
    },
    "size_adjustment_ratio": {
      "default": 0.0,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Size Adjustment Ratio",
      "type": "number"
    },
    "measured_value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Measured Value"
    },
    "limit_value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Limit Value"
    },
    "snapshot_id": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Snapshot Id"
    },
    "exposure_headroom_snapshot": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Exposure Headroom Snapshot",
      "type": "object"
    },
    "auto_resize_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Auto Resize Reason"
    },
    "operating_mode": {
      "enum": [
        "live",
        "paused",
        "hold"
      ],
      "title": "Operating Mode",
      "type": "string"
    },
    "operating_state": {
      "default": "TRADABLE",
      "title": "Operating State",
      "type": "string"
    },
    "effective_leverage_cap": {
      "exclusiveMinimum": 0.0,
      "maximum": 10.0,
      "title": "Effective Leverage Cap",
      "type": "number"
    },
    "symbol_risk_tier": {
      "enum": [
        "btc",
        "major_alt",
        "alt"
      ],
      "title": "Symbol Risk Tier",
      "type": "string"
    },
    "exposure_metrics": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Exposure Metrics",
      "type": "object"
    },
    "sync_freshness_summary": {
      "additionalProperties": true,
      "title": "Sync Freshness Summary",
      "type": "object"
    },
    "debug_payload": {
      "additionalProperties": true,
      "title": "Debug Payload",
      "type": "object"
    }
  },
  "required": [
    "allowed",
    "decision",
    "reason_codes",
    "approved_risk_pct",
    "approved_leverage",
    "operating_mode",
    "effective_leverage_cap",
    "symbol_risk_tier"
  ],
  "title": "RiskCheckResult",
  "type": "object"
}
