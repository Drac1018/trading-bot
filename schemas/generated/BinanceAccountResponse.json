  "additionalProperties": false,
  "properties": {
    "summary": {
      "$ref": "#/$defs/BinanceAccountSummary"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/BinanceAccountAsset"
      },
      "title": "Assets",
      "type": "array"
    },
    "positions": {
      "items": {
        "$ref": "#/$defs/BinanceAccountPosition"
      },
      "title": "Positions",
      "type": "array"
    },
    "open_orders": {
      "items": {
        "$ref": "#/$defs/BinanceOpenOrderSummary"
      },
      "title": "Open Orders",
      "type": "array"
    }
  },
  "required": [
    "summary"
  ],
  "title": "BinanceAccountResponse",
  "type": "object"
}