      "type": "string"
    },
    "quantity": {
      "exclusiveMinimum": 0.0,
      "title": "Quantity",
      "type": "number"
    },
    "requested_price": {
      "exclusiveMinimum": 0.0,
      "title": "Requested Price",
      "type": "number"
    },
    "entry_mode": {
