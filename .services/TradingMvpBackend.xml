<service>
  <id>TradingMvpBackend</id>
  <name>Trading MVP Backend</name>
  <description>FastAPI backend for the trading MVP</description>
  <executable>powershell.exe</executable>
  <arguments>-NoProfile -ExecutionPolicy Bypass -File "C:\my-trading-bot\scripts\\run_backend.ps1"</arguments>
  <workingdirectory>C:\my-trading-bot</workingdirectory>
  <stoptimeout>15 sec</stoptimeout>
  <resetfailure>1 hour</resetfailure>
  <onfailure action="restart" delay="10 sec" />
  <logpath>C:\my-trading-bot\.logs\\services\\backend</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyyMMdd</pattern>
    <keepFiles>8</keepFiles>
  </log>
</service>
